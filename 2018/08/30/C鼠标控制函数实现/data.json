an class=\"line\">    <span class=\"built_in\">ShowWindow</span>(hwnd,SW_HIDE);</span><br><span class=\"line\">    POINT p;</span><br><span class=\"line\">    <span class=\"type\">int</span> i=<span class=\"number\">1</span>;</span><br><span class=\"line\">    <span class=\"type\">int</span> a=<span class=\"built_in\">GetSystemMetrics</span>(SM_CXSCREEN);</span><br><span class=\"line\">    <span class=\"type\">int</span> b=<span class=\"built_in\">GetSystemMetrics</span>(SM_CYSCREEN);</span><br><span class=\"line\">    <span class=\"keyword\">while</span>(<span class=\"number\">1</span>)&#123;</span><br><span class=\"line\">        <span class=\"built_in\">GetCursorPos</span>(&amp;p);</span><br><span class=\"line\">        <span class=\"keyword\">if</span>(p.x&gt;=a<span class=\"number\">-1</span>)&#123;</span><br><span class=\"line\">            <span class=\"built_in\">SetCursorPos</span>(<span class=\"number\">1</span>,p.y);</span><br><span class=\"line\">        &#125;</span><br><span class=\"line\">        <span class=\"keyword\">if</span>(p.y&gt;=b<span class=\"number\">-1</span>)&#123;</span><br><span class=\"line\">            <span class=\"built_in\">SetCursorPos</span>(p.x,<span class=\"number\">1</span>);</span><br><span class=\"line\">        &#125;</span><br><span class=\"line\">        <span class=\"keyword\">if</span>(p.x==<span class=\"number\">0</span>)&#123;</span><br><span class=\"line\">            <span class=\"built_in\">SetCursorPos</span>(a<span class=\"number\">-1</span>,p.y);</span><br><span class=\"line\">        &#125;</span><br><span class=\"line\">        <span class=\"keyword\">if</span>(p.y==<span class=\"number\">0</span>)&#123;</span><br><span class=\"line\">            <span class=\"built_in\">SetCursorPos</span>(p.x,b<span class=\"number\">-1</span>);</span><br><span class=\"line\">        &#125;</span><br><span class=\"line\">        _sleep(<span class=\"number\">10</span>);</span><br><span class=\"line\">    &#125;</span><br><sp